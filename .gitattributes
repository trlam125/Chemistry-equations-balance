# Normalize text files in the repository and use LF in Git.
* text=auto eol=lf

# Windows command scripts require CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Source and configuration files.
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files must never be modified by line-ending normalization.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.apk binary
*.aab binary
*.jar binary
*.zip binary
*.keystore binary
*.jks binary
*.p12 binary
*.pdf binary

# Improve GitHub language statistics for generated/build helper files.
dist/** linguist-generated=true
tests/test_results_*.txt linguist-generated=true
